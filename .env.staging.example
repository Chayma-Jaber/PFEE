# ════════════════════════════════════════════════════════════════════════════
# Barsha — STAGING environment overlay (used by docker-compose.staging.yml)
# ════════════════════════════════════════════════════════════════════════════
# Copy to .env.staging and fill in the [FILL_ME] markers before bringing the
# stack up. Leave commented values to use the configuration default.
#
# What this file overrides vs backend/.env.example:
#   - DB_HOST/USERNAME/PASSWORD/NAME → in-compose MSSQL container
#   - MEILISEARCH_URL/TOKEN → in-compose Meilisearch container
#   - AI_SERVICE_URL / OLLAMA_URL → in-compose containers
#   - JWT_SECRET → MUST be set (app refuses to boot otherwise in production)
#   - CORS_ORIGINS / FRONTEND_URL → public URL of the staging host
# ════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=8000

# ─── Database (the in-compose mssql container) ──────────────────────────────
DB_TYPE=mssql
DB_HOST=mssql
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=Barsha-Staging-2026!
DB_NAME=barsha
DB_POOL_SIZE=10

# ─── JWT — REQUIRED ─────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 64
JWT_SECRET=[FILL_ME_64_CHARS]
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS / public URLs ─────────────────────────────────────────────────────
# Replace with the real staging host(s).
CORS_ORIGINS=http://localhost,https://staging.barsha.com.tn
CORS_ALLOW_CREDENTIALS=true
APP_URL=https://staging-api.barsha.com.tn
FRONTEND_URL=https://staging.barsha.com.tn

# ─── Search ─────────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_TOKEN=barsha-staging-master-key

# ─── AI ─────────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai-service:8001
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ─── Payment (sandbox in staging — DO NOT switch CTP_SANDBOX_MODE to false
# without real merchant credentials from the bank) ──────────────────────────
CTP_MERCHANT_ID=
CTP_API_KEY=
CTP_SECRET_KEY=
CTP_API_URL=https://api.sandbox.ctp.tn
CTP_SANDBOX_MODE=true

# ─── Email (Mailtrap or Ethereal sandbox SMTP for safe staging) ─────────────
# Mailtrap: smtp.mailtrap.io / 2525 / your inbox creds → emails caught in UI
# Ethereal: ethereal.email — auto-generates throwaway creds at runtime
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=[FILL_ME]
SMTP_PASSWORD=[FILL_ME]
EMAIL_FROM=noreply@staging.barsha.com.tn
EMAIL_FROM_NAME=Barsha (staging)

# ─── SMS (console = logs only, no real send) ────────────────────────────────
SMS_ENABLED=true
SMS_PROVIDER=console
SMS_FROM=Barsha
SMS_DEFAULT_COUNTRY_CODE=+216

# ─── Shipping (off in staging) ──────────────────────────────────────────────
FIRST_DELIVERY_API_KEY=
ARAMEX_ACCOUNT_NUMBER=

# ─── Loyalty / alerts ───────────────────────────────────────────────────────
LOYALTY_ENABLED=true
LOYALTY_POINTS_PER_DINAR=10
LOYALTY_REDEMPTION_RATE=100
ALERTS_ENABLED=true

# ─── Fiscal (off in staging — receipts get LOCAL stamp) ─────────────────────
FISCAL_ISSUER_MATRICULE=0000000A/A/M/000
FISCAL_TTN_ENABLED=false

# ─── Admin seed (only used by `npm run seed`) ───────────────────────────────
ADMIN_EMAIL=admin@staging.barsha.com.tn
ADMIN_PASSWORD=[FILL_ME]
